# Copy this file to mobile/android/local.properties before building the Android wrapper.
# Do not commit mobile/android/local.properties; it can contain your private server URL.

# Android SDK path for local builds.
sdk.dir=/path/to/android-sdk

# Optional public HTTPS URL for your Switchboard server.
# Leave blank for generic/F-Droid-style builds; the app will ask for a server
# URL on first launch.
SWITCHBOARD_APP_URL=
