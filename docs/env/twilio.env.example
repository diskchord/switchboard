# Twilio messaging and voice.
# Public callback URL, assuming your Switchboard host is:
# https://switchboard.example

# Use Twilio as the default provider for outbound sends.
TEXTING_MESSAGING_PROVIDER=twilio

# Add every Twilio sender number you own here or in core.env.example.
TEXTING_PERSONAL_NUMBERS=+15551230002
TEXTING_IDENTITY_LABELS={"+15551230002":"Twilio"}

# Twilio API credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_BASE=https://api.twilio.com

# Recommended when a reverse proxy rewrites the request URL.
TWILIO_WEBHOOK_URL=https://switchboard.example/api/twilio/webhook
TWILIO_STATUS_CALLBACK_URL=https://switchboard.example/api/twilio/webhook

# Twilio Messaging webhook for regular SMS/MMS:
# https://switchboard.example/api/twilio/webhook

# Inbound Twilio Group MMS:
# Create a Twilio Event Streams webhook sink pointed at the same URL and
# subscribe to com.twilio.messaging.inbound-message.received schema v5 or newer.
# Switchboard reads the Event Streams recipients array to identify the group.

# Twilio voice webhook:
# https://switchboard.example/api/twilio/voice
#
# Switchboard returns recording/transcription callback URLs automatically:
# https://switchboard.example/api/twilio/voice/recording
# https://switchboard.example/api/twilio/voice/transcription
