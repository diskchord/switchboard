# Contact sync examples.
# Choose CONTACTS_PROVIDER=fastmail, google, auto, or none.

CONTACTS_PROVIDER=auto
CONTACTS_AUTOSYNC=1
CONTACTS_SYNC_INTERVAL_MINUTES=360

# Fastmail CardDAV contacts.
FASTMAIL_USERNAME=
FASTMAIL_APP_PASSWORD=
FASTMAIL_CARDDAV_URL=
FASTMAIL_CARDDAV_USERNAME=

# Legacy Fastmail JMAP token mode.
FASTMAIL_API_TOKEN=
FASTMAIL_ACCOUNT_ID=

# Google Contacts via People API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_PEOPLE_API_BASE=https://people.googleapis.com/v1

# Optional short-lived access token for testing.
GOOGLE_CONTACTS_ACCESS_TOKEN=
