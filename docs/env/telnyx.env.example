# Telnyx messaging, fax, and voice.
# Public callback URL, assuming your Switchboard host is:
# https://switchboard.example

# Use Telnyx as the default provider for outbound sends.
TEXTING_MESSAGING_PROVIDER=telnyx

# Add every Telnyx sender number you own here or in core.env.example.
TEXTING_PERSONAL_NUMBERS=+15551230001
TEXTING_IDENTITY_LABELS={"+15551230001":"Telnyx"}

# Telnyx API credentials.
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_API_BASE=https://api.telnyx.com/v2

# Telnyx Messaging Profile webhook:
# https://switchboard.example/api/telnyx/webhook
#
# Use the same endpoint for inbound SMS/MMS and delivery events.
# Telnyx Group MMS payloads include the recipient list, so Switchboard can
# store inbound group participants automatically when Telnyx sends them.

# Telnyx Programmable Fax Application webhook:
# https://switchboard.example/api/telnyx/webhook

# Telnyx TeXML voice webhook:
# https://switchboard.example/api/telnyx/voice
#
# Switchboard returns recording/transcription callback URLs automatically:
# https://switchboard.example/api/telnyx/voice/recording
# https://switchboard.example/api/telnyx/voice/transcription
