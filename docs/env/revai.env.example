# Rev.ai voicemail transcription.
# Use this when provider-supplied voicemail transcripts are not enough.

TEXTING_VOICEMAIL_TRANSCRIPTION_PROVIDER=revai
REVAI_ACCESS_TOKEN=
REVAI_API_BASE=https://api.rev.ai/speechtotext/v1

# Rev.ai callback URL:
# https://switchboard.example/api/revai/webhook
#
# Switchboard submits provider recordings to Rev.ai and stores the completed
# transcript as a voicemail message in the caller's conversation.
