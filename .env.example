# Server
TEXTING_HOST=127.0.0.1
TEXTING_PORT=8766
# Docker Compose host port; ignored when running server.py directly.
SWITCHBOARD_PORT=8766
TEXTING_DATA_DIR=/var/lib/switchboard
TEXTING_DB=/var/lib/switchboard/switchboard.sqlite
TEXTING_MEDIA_DIR=/var/lib/switchboard/media

# App sign-in. Generate the password hash with:
# python scripts/hash_password.py
TEXTING_AUTH_USERNAME=
TEXTING_AUTH_PASSWORD_HASH=
# Optional but recommended. Generate with: python -m texting_app.auth secret-key
TEXTING_AUTH_SECRET_KEY=
TEXTING_AUTH_SESSION_DAYS=14
# Optional app-based 2FA. Generate with:
# python -m texting_app.auth setup-2fa --username admin
TEXTING_AUTH_TOTP_SECRET=
TEXTING_AUTH_TOTP_ISSUER=Switchboard
TEXTING_AUTH_BACKUP_CODE_HASHES=
# Set to 1 only for trusted local development with another access boundary.
TEXTING_AUTH_DISABLED=0

# Sender identities. Add phone numbers you own/control in Telnyx or Twilio.
# Prefer E.164 format. 10/11 digit North American numbers are accepted too.
TEXTING_PERSONAL_NUMBERS=+15551230001,+15551230002
TEXTING_IDENTITY_LABELS={"+15551230001":"Personal","+15551230002":"Work"}

# Messaging provider: telnyx or twilio.
# If all sender numbers use one provider, set TEXTING_MESSAGING_PROVIDER only.
# If you mix Telnyx and Twilio numbers, map each sender number here.
TEXTING_MESSAGING_PROVIDER=telnyx
TEXTING_PROVIDER_BY_NUMBER={"+15551230001":"telnyx","+15551230002":"twilio"}

# Telnyx
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_API_BASE=https://api.telnyx.com/v2

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_BASE=https://api.twilio.com
TWILIO_WEBHOOK_URL=
TWILIO_STATUS_CALLBACK_URL=

# Voicemail transcription: provider or revai.
# Call forwarding and voicemail defaults are managed in Settings > Calls and per sender number.
TEXTING_VOICEMAIL_TRANSCRIPTION_PROVIDER=provider
REVAI_ACCESS_TOKEN=
REVAI_API_BASE=https://api.rev.ai/speechtotext/v1

# UI
TEXTING_UI_LANGUAGE=auto
TEXTING_AUTO_REFRESH_SECONDS=15
TEXTING_SHOW_SUMMARY_STATS=1
TEXTING_SHOW_COMPOSER_COUNTER=1

# Incoming-message notification. Leave blank to disable.
NTFY_ENDPOINT=
NTFY_ENABLED=1

# Optional Android app native notifications. Periodic checks have a 15 minute minimum.
TEXTING_NATIVE_NOTIFICATIONS_ENABLED=0
TEXTING_NATIVE_NOTIFICATION_INTERVAL_MINUTES=15

# Browser/app sound effects. Receive sound auto is silent when ntfy is active.
TEXTING_SEND_SOUND_ENABLED=1
TEXTING_SEND_SOUND_TONE=ascending
TEXTING_RECEIVE_SOUND=auto
TEXTING_RECEIVE_SOUND_TONE=chime
TEXTING_SOUND_VOLUME=45

# Outbound MMS and voicemail-greeting upload staging.
# Switchboard serves this directory at /uploads. Leave the base URL blank to
# derive it from the public request host, or set an explicit provider-reachable URL.
TEXTING_PUBLIC_UPLOAD_DIR=/var/lib/switchboard/public-uploads
TEXTING_PUBLIC_UPLOAD_BASE_URL=
TEXTING_UPLOAD_MAX_FILE_MB=25
TEXTING_CACHE_ATTACHMENTS=1

# Contacts: auto, fastmail, google, or none.
CONTACTS_PROVIDER=auto
CONTACTS_AUTOSYNC=1
CONTACTS_SYNC_INTERVAL_MINUTES=360

# Fastmail CardDAV contacts
FASTMAIL_USERNAME=
FASTMAIL_APP_PASSWORD=
FASTMAIL_CARDDAV_URL=
FASTMAIL_CARDDAV_USERNAME=

# Legacy Fastmail JMAP token mode
FASTMAIL_API_TOKEN=
FASTMAIL_ACCOUNT_ID=

# Google Contacts via People API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_PEOPLE_API_BASE=https://people.googleapis.com/v1
# Optional short-lived token for testing instead of refresh-token auth.
GOOGLE_CONTACTS_ACCESS_TOKEN=
